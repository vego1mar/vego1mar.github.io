# rsync -vrhupXgolt --del --dry-run ~/library/roboczy/ /run/media/$USER/crucial-backup/backup-data/roboczy/ | less
# rsync -vrhupXgolt --del --progress ~/library/roboczy/ /run/media/$USER/crucial-backup/backup-data/roboczy/
function copy_data() {
  local device="$1"
  local dir="$2";
  local options="$3";
  local source=~/library/"$dir"/;
  local target=/run/media/$USER/"$device"/"$dir"/;

  echo "[$0] source = $source";
  echo "[$0] target = $target";
  echo "[$0] status = $(file -b "$source")";
  echo "[$0] status = $(file -b "$target")";

  echo -n "[$0] continue? [enter ctrl+c] ";
  read -r;

  rsync -vrhptgolu --del --dry-run "$source" "$target" | less
  echo -n "[$0] continue? [yn] ";
  read -r;
  local choice="${REPLY:0:1}";

  if [[ $choice == y ]]; then 
    echo "[$0] if-branch = yes";
    echo -n "[$0] continue? [enter ctrl+c]";
    if [ -z "$options" ]; then rsync -vrhupXgolt --del "$source" "$target";
    else rsync -vrhupXgolt --del "$options" "$source" "$target";
    fi
  else 
    echo "[$0] if-branch = no";
  fi
}


