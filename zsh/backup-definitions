#!/bin/zsh

set -o pipefail;


# make_vivaldi_profile
function make_vivaldi_profile() {
  rm ~/library/roboczy/app-data/vivaldi/profile-26*.7z
  local ts;
  ts=$(date --iso-8601 | cut -c3,4,6,7,9,10);
  7z a -t7z ~/library/roboczy/app-data/vivaldi/profile-"$ts".7z ~/.config/vivaldi/Default
  unset ts;
}


# make_vnstat_database
function make_vnstat_database() {
  local ts;
  ts=$(date --iso-8601 | cut -c3,4,6,7,9,10)
  7z a -ttar ~/library/roboczy/app-data/vnstat/cachyos-netuse-"$ts".tar /var/lib/vnstat/vnstat.db /etc/vnstat.conf
  unset ts
}


# make_thunderbird_profile loolnehx.default-release
function make_thunderbird_profile() {
  rm ~/library/roboczy/app-data/thunderbird/profile-26*.7z
  local -r tid="$1";
  local -r ts=$(date --iso-8601 | cut -c3,4,6,7,9,10);
  7z a -t7z ~/library/roboczy/app-data/thunderbird/profile-"$ts".7z ~/.thunderbird/"$tid"
