# str=$(awk 'NR>=555 && NR<=562' ~/library/documents/db/recenzje/hitman-woa); generate_escalations_entry "$str";
function generate_escalations_entry() {
  local -r n_lines=$(echo "$1" | wc -l);
  local output="<tr>\n";
  
  local date_=$(echo "$1" | cut -d $'\n' -f1);
  local name=$(echo "$1" | cut -d $'\n' -f2);  
  local all_levels=$(echo "$1" | cut -d $'\n' -f3);
  local main_url=$(echo "$all_levels" | cut -d\| -f1);
  local main_durations=$(echo "$all_levels" | cut -d\| -f2);
  date_=$(trim_str "$date_");
  name=$(trim_str "$name");
  main_url=$(trim_str "$main_url");
  main_durations=$(trim_str "$main_durations");
  output+="\t<td>$date_</td>\n";
  output+="\t<td><a href=\"$main_url\">$name</a></td>\n";
  output+="\t<td>$main_durations</td>\n";
  
  local td="\t<td>\n";
  for ((i=4; i <= $n_lines; i++)); do
    local entry=$(echo "$1" | cut -d $'\n' -f"$i");
    local url=$(echo "$entry" | cut -d\| -f1);
    local level=$(echo "$entry" | cut -d\| -f2);
    local duration=$(echo "$entry" | cut -d\| -f3);
    url=$(trim_str "$url");
    level=$(trim_str "$level");
    duration=$(trim_str "$duration");
    td+="\t\t<a href=\"$url\">$duration</a>, \n";
  done
  
  td=${td:0:-4}'\n';
  td+="\t</td>\n";
  output+="$td";
  output+="</tr>\n";
  echo "$output";
}


