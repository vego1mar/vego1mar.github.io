# generate_achievements_table "--- base game\nUnseen Assassin | Assassinate a Target without getting spotted.\nSilent Sniper | Complete The Last Yardbird as Silent Assassin. | https://www.youtube.com/watch?v=OedhC3F7UR4"
# str=`awk 'NR>=1235 && NR<=1246' ~/library/documents/db/recenzje/hitman-woa`; generate_achievements_table "$str";
function generate_achievements_table() {
  local output="<table class=\"achievements\">\n";
  local n_lines=$(echo "$1" | wc -l);
  local lines=();

  local entry=$(echo "$1" | cut -d $'\n' -f1);
  if [[ $(echo "$entry" | cut -c1-4) == "--- " ]]; then
    local text=$(echo "$entry" | cut -c5-);
    text=$(to_lowercase "$text");
    output+="\t<caption>$text</caption>\n";
    output+="\t<tr>\n\t\t<td class=\"achievements--name\"></td>\n\t\t<td></td>\n\t</tr>\n";
  fi
      
  for ((i=2; i <= $n_lines; i++)); do
    local entry=$(echo "$1" | cut -d $'\n' -f"$i");

    local name=$(echo "$entry" | cut -d\| -f1);
    local desc=$(echo "$entry" | cut -d\| -f2);
    local url=$(echo "$entry" | cut -d\| -f3);
    name=$(trim_str "$name");
    desc=$(trim_str "$desc");
    name=$(to_lowercase "$name");
    desc=$(to_lowercase "$desc");
    
    if [ -n "$url" ]; then
      url=$(trim_str "$url");
      output+="\t<tr>\n\t\t<td><a href=\"$url\">$name</a></td>\n\t\t<td>$desc</td>\n\t</tr>\n";
    else
      output+="\t<tr>\n\t\t<td>$name</td>\n\t\t<td>$desc</td>\n\t</tr>\n";
    fi
  done
  
  output+="</table>\n<br>\n";
  echo "$output";
}

