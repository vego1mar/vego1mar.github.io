#!/bin/zsh


# trim_str "  aaa bbb \n"
function trim_str() {
  local var="$1";
  local trim=${${var%${var##*[^[:blank:]]}}#${${var%${var##*[^[:blank:]]}}%%[^[:blank:]]*}};
  echo "$trim";
}


# to_lowercase AAA
function to_lowercase() {
  local text="$1";
  echo ${(L)text};
}


function str_between_2() {
  local result;
  result=$(print "$1" | grep -o -P "(?<=$2).*(?=$3)");
  stdout "$result";
}


# generate_unsorted_list "https://www.nexusmods.com/hitman3/mods/200 | simple mod framework\nhttps://www.nexusmods.com/hitman3/mods/784 | hitman world of assassination unofficial community patch"
# str=$(cat ~/library/documents/db/recenzje/hitman-woa | head -38 | tail +26) && generate_unsorted_list "$str";
function generate_unsorted_list() {
  local output="<ul>\n";
  local n_lines=$(echo "$1" | wc -l);
  local lines=();

  for ((i=1; i <= $n_lines; i++)); do
    local entry=$(echo "$1" | cut -d $'\n' -f"$i");
    
    local url=$(echo "$entry" | cut -d\| -f1);
    local desc=$(echo "$entry" | cut -d\| -f2);
    url=$(trim_str "$url");
    desc=$(trim_str "$desc");
    
    output+="\t<li><a href=\""$url"\">"$desc"</a></li>\n";
  done
  
  output+="</ul>";
  echo "$output";
}


# generate_soundtrack_table "--- hitman 1\nhttps://www.youtube.com/watch?v=9b-nHWlD0C4 | e3 2015 announcement trailer song | 6m6s\nhttps://www.youtube.com/watch?v=2Vg05bVsT-A | legacy opening cinematic | 2m18s"
function generate_soundtrack_table() {
  local output="<table class=\"soundtrack-ost\">\n";
  local n_lines=$(echo "$1" | wc -l);
  local lines=();

  local entry=$(echo "$1" | cut -d $'\n' -f1);
  if [[ $(echo "$entry" | cut -c1-4) == "--- " ]]; then
    local text=$(echo "$entry" | cut -c5-);
    output+="\t<caption>$text</caption>\n";
    output+="\t<tr>\n\t\t<td class=\"soundtrack-ost--name\"></td>\n\t\t<td></td>\n\t</tr>\n";
  fi
      
  for ((i=2; i <= $n_lines; i++)); do
    local entry=$(echo "$1" | cut -d $'\n' -f"$i");

    local url=$(echo "$entry" | cut -d\| -f1);
    local desc=$(echo "$entry" | cut -d\| -f2);
    local dur=$(echo "$entry" | cut -d\| -f3);
    url=$(trim_str "$url");
    desc=$(trim_str "$desc");
    dur=$(trim_str "$dur");
    
    local min=$(echo "$dur" | grep -o '^[0-9]*[m$]' | tr 'm' ':');
    local sec=$(echo "$dur" | grep -o '[^m][0-9]*[s$]');
    if [[ $#sec == 2 ]]; then
      sec="0$sec";
    fi
    sec="${sec:0:-1}";
    local duration="$min$sec";

    output+="\t<tr>\n\t\t<td><a href=\"$url\">$desc</a></td>\n\t\t<td>$duration</td>\n\t</tr>\n";
  done
  
  output+="</table>";
  echo "$output";
}


