# f: record_type_2 file_name -> string | <...>
function transpose_yt2_to_movie_record() {
  local input="$1";
  local file_name="$2";

  local separators=0;
  separators=$(str_count_occurrences "$input" '|');
  if ! str_equals "$separators" '7'; then
    stderr "[$0] not proper record_type_2 (separators = $separators)";
    return 77;
  fi

  local title;
  title=$(print "$input" | cut -d\| -f1);
  title=$(str_to_lowercase "$title");

  local author;
  local profile_id;
  author=$(print "$input" | cut -d\| -f2);
  profile_id=$(str_before "$author" '[');
  profile_id=$(str_trim "$profile_id");
  profile_id=$(str_to_lowercase "$profile_id");
  author=$(str_between_by_index "$author" '[' ']');
  author=$(str_to_lowercase "$author");

  local rdate;
  rdate=$(print "$input" | cut -d\| -f3);
  rdate=$(str_trim "$rdate");

  local duration;
  duration=$(print "$input" | cut -d\| -f4);

  local link;
  link=$(print "$input" | cut -d\| -f8);

  local output;
  local now;
  local new_str;
  now=$(date -I);
  output="$title| $author | $profile_id | $rdate |$duration| __hash__ | #created:$now #__cat__ #_ |$link";
  if str_equals "$profile_id" "@cppweekly"; then
    output=$(str_replace "$output" '#__cat__' '#c++');
    output=$(str_replace "$output" 'c++ weekly with jason turner' 'jason turner');
  elif str_equals "$profile_id" "@cppcon"; then
    output=$(str_replace "$output" '#__cat__' '#c++');
    new_str=$(str_between_by_index "$title" '- ' ' -' );
    output=$(str_replace "$output" '| cppcon |' "| $new_str |");
    new_str=$(str_before "$title" ' -');
    output=$(str_replace "$output" "$title" "$new_str ");
  elif str_equals "$profile_id" "@numberphile"; then
    output=$(str_replace "$output" '#__cat__' '#math');
    output=$(str_replace "$output" ' - numberphile' '');
    output=$(str_replace "$output" '| numberphile |' '| __people__ |');
  elif str_equals "$profile_id" "@computerphile"; then
    output=$(str_replace "$output" '#__cat__' '#cs');
    output=$(str_replace "$output" ' - computerphile' '');
    output=$(str_replace "$output" '| computerphile |' '| __people__ |');
