# transpose_duration 1m58s,2m28s,2m57s
# transpose_duration 1m,2m,11s
# transpose_duration 174m17s
# transpose_duration 179m59s,1s
function transpose_duration() {
  # https://unix.stackexchange.com/questions/23227/for-loops-in-zsh-and-bash
  # https://stackoverflow.com/questions/74441977/how-to-get-length-of-string-in-zsh-from-function-output
  # https://stackoverflow.com/questions/23157613/how-to-iterate-through-string-one-word-at-a-time-in-zsh
  # https://unix.stackexchange.com/questions/295033/loop-over-a-string-in-zsh-and-bash
  # https://superuser.com/questions/1686176/zsh-iterate-through-string-array-containing-spaces
  # https://stackoverflow.com/questions/10551981/how-to-perform-a-for-loop-on-each-character-in-a-string-in-bash
  # https://superuser.com/questions/1098551/append-string-to-array-elements-and-join-them-in-one-expression
  # https://stackoverflow.com/questions/4181703/how-to-concatenate-string-variables-in-bash
  # https://unix.stackexchange.com/questions/645927/check-if-a-number-is-in-a-range-with-zsh
  # https://zsh.sourceforge.io/Doc/Release/Arithmetic-Evaluation.html
  # https://zsh.sourceforge.io/Doc/Release/Conditional-Expressions.html
  # https://stackoverflow.com/questions/18668556/how-can-i-compare-numbers-in-bash
  
  local durations="$1";
  local number="";
  local minutes="";
  local seconds="";

  {
  # https://unix.stackexchange.com/questions/614299/how-to-split-a-string-by-character-in-bash-zsh#614304
  # shellcheck disable=SC2296
  # shellcheck disable=SC2206
  local entries=(${(s[,])durations});
  local occurrences_of_m=0;
  local occurrences_of_s=0;
  local occurrences_of_h=0;
  local first_dur=${entries[1]};
  local -r n_first_dur=${#entries[1]};
  local h;
  h=$(print "$first_dur" | tr -cd "h" | wc -c);
  occurrences_of_h=$(( occurrences_of_h + h ));
  if [ "$occurrences_of_h" -gt 0 ]; then stderr "[$0] do not use hours"; return 1; fi
  local s;
  local m;
  m=$(print "$first_dur" | tr -cd "m" | wc -c);
  s=$(print "$first_dur" | tr -cd "s" | wc -c);
  occurrences_of_m=$(( occurrences_of_m + m ));
  occurrences_of_s=$(( occurrences_of_s + s ));
  local occurrences=$(( occurrences_of_m + occurrences_of_s ));
  local -r is_only_h_or_m=$(if [ $occurrences -eq 1 ]; then print "true"; else print "false"; fi);
  if [[ "$is_only_h_or_m" == "true" ]]; then
    if [[ "$occurrences_of_m" == 1 ]]; then first_dur="$first_dur""0s"; fi
    if [[ "$occurrences_of_s" == 1 ]]; then first_dur="0m""$first_dur"; fi
  fi
  unset occurrences_of_s occurrences_of_m s m h entries;
  }
  
  durations="$first_dur""${durations:$n_first_dur}";

  for (( i=0; i<$#durations; i++ )); do
    local ch=${durations:$i:1};

    if [[ "$ch" == "m" ]]; then 
      minutes+="$number+";
      number="";
      continue;
    elif [[ "$ch" == "s" ]]; then
      seconds+="$number+";
      number="";
      continue;
    elif [[ "$ch" == "," ]]; then
      continue;
    fi
    
    number+="$ch";
  done

  local output="";
  local min;
  local sec;
  min=$(print "${minutes:0:-1}" | bc -l);
  sec=$(print "${seconds:0:-1}" | bc -l);
  output+="$min"m"$sec"s;

  local coeff;
  local conv=$sec;

  if (( sec >= 60 )); then
    coeff=$(print "$sec/60" | bc);
    conv=$(print "$sec-(60*$coeff)" | bc);
    min=$(print "$min+$coeff" | bc);
    output+=" → $min""m$conv"s;
  fi

  if (( min >= 60 )); then
    sec=$conv;
    coeff=$(print "$min/60" | bc);
    conv=$(print "$min-(60*$coeff)" | bc);
    min=$(print "$min+$conv" | bc);
    output+=" → $coeff""h$conv""m$sec"s;
  fi

  stdout "$output";
}

