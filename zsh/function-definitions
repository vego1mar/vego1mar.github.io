# take_json_class " { "key": "is_alc_surface", "value": "false" }, { "key": "ipcc", "value": "0" } }"
function take_json_class() {
  local -r json="$1";

  local -r len=$#json;
  local ch;
  typeset -a stack=();
  local i;
  local is_first="false";
  local is_last="false";
  local index_first=0;
  local index_last=0;

  for (( i=1; i<=len; i++ )); do
    char="${json[$i]}";
    if str_equals "$char" "{"; then
      stack+=('{');
      if str_equals "$is_first" "false"; then
        is_first="true";
        index_first=$i;
      fi
    elif str_equals "$char" "}"; then
      arr_remove_at_index "stack" "$#stack";
      if (( $#stack == 0 )) && str_equals "$is_last" "false"; then
        is_last="true";
        index_last=$i;
        break;
      fi
    fi
  done

  local -r left=$(( index_first - 1 ));
  local -r right=$(( index_last - index_first + 1 ));
  local -r json_class=${json:$left:$right};
  stdout "$json_class";
}
