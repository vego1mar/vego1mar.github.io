# ___test__print "$output" "$expected" "$0" "description" -> string | <...>
function ___test__print() {
  local output="$1";
  local expected="$2";
  local func="$3";
  local description="$4";

  # https://www.dotlinux.net/blog/bash-script-string-comparison-examples/#1-equality-check--or-
  # https://kodekloud.com/blog/bash-compare-strings/
  # https://linuxize.com/post/how-to-compare-strings-in-bash/
  # https://stackoverflow.com/questions/454427/string-difference-in-bash#454549
  local difference;
  difference=$(diff <(print -- "$output") <(print -- "$expected"));

  if [ -z "$difference" ]; then
    print -u1 -- "✅ [$func] $description";
  else
    # 31 red, 32 green
    print -u2 -- "❌ [$func] $description | out=(\e[31m$output\e[m) | exp=(\e[32m$expected\e[m)";
  fi
}

