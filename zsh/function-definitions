function get_next_glyph() {
  # https://www.baeldung.com/linux/shell-ascii-value-character
  # https://unix.stackexchange.com/questions/44747/printing-decimal-to-ascii-character-my-command-does-not-output-as-intended
  # https://www.w3tutorials.net/blog/how-do-you-echo-a-4-digit-unicode-character-in-bash/
  # https://github.com/koalaman/shellcheck/wiki/SC2059
  # https://discuss.kakoune.com/t/insert-unicode-characters-by-codepoint-with-printf/2520
  # https://unix.stackexchange.com/questions/551630/get-the-unicode-code-point-of-a-character-in-zsh
  local glyph="$1";

  #  printf '%d' "'彭"    # 24429
  #  printf '%x' "'彭"    # 5f6d
  #  printf '%x' 24429    # 5f6d
  #  printf '\u5f6d'      # 彭
  local decimal_code_point;
  local next_code_point;
  local hex_code_point;
  local next_unicode_char;
  decimal_code_point=$(printf '%d' "'$glyph");
  next_code_point=$(( decimal_code_point + 1 ));
  hex_code_point=$(printf '%x' "$next_code_point");
  # shellcheck disable=SC2059
  next_unicode_char=$(printf "\u$hex_code_point");

  if str_equals "$decimal_code_point" "1114111"; then
    # https://stackoverflow.com/questions/27415935/does-unicode-have-a-defined-maximum-number-of-code-points#27416004
    # https://stackoverflow.com/questions/602912/how-do-you-echo-a-4-digit-unicode-character-in-bash#602924
    # last glyph: u+10ffff
    next_unicode_char="";
  fi

  stdout "$next_unicode_char";
}
