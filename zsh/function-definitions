# stderr "error_message" -> string | <...>
function stderr() {
  # https://linuxcommandlibrary.com/man/print.zsh
  # https://stackoverflow.com/questions/4842424/list-of-ansi-color-escape-sequences#75985833
  # ansi red
  print -u2 -n "\e[31m"
  print -u2 -n -- "$@";
  print -u2 "\e[m";
}

# stdout "standard_output_message" -> string | <...>
function stdout() {
  # https://unix.stackexchange.com/questions/22764/dashes-in-printf
  # https://superuser.com/questions/1371834/escaping-hyphens-with-printf-in-bash
  # https://www.baeldung.com/linux/dash-in-command-line-parameters
  print -u1 -- "$@";
}
