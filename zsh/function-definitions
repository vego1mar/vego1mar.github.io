# f: "url|name|author|[album|]duration\n..." -> string | <...>
function htmlgen_soundtrack3_table() {
  local input="$1";
  local external_tags;
  external_tags="<details class=\"accordion\">
  <summary>soundtrack</summary>
  <table class=\"soundtrack3\">
    <colgroup>
      <col span=\"1\"> <!-- info: (title, authors, album) -->
      <col span=\"1\"> <!-- duration -->
    </colgroup>";
  stdout "$external_tags";

  local n_lines;
  n_lines=$(echo "$input" | wc -l);

  local line;
  local line_type;
  local url;
  local title;
  local author;
  local duration;
  local album;
  local current_row;
  for (( i=1; i<=n_lines; i++ )); do
    line=$( awk 'NR=='"$i" <(print "$input") );
    url=$(str_trim_right "$(print "$line" | cut -d\| -f1)" );
    title=$(str_trim "$(print "$line" | cut -d\| -f2)" );
    author=$(str_trim "$(print "$line" | cut -d\| -f3)" );

    line_type=$(str_count_occurrences "$line" '|');
    if (( line_type == 3 )); then
      duration=$(str_trim_left "$(print "$line" | cut -d\| -f4)" );
      current_row="    <tr>
      <td>
        <a href=\"$url\">$title</a><br>
        $author<br>
      </td>
      <td>$duration</td>
    </tr>";
    elif (( line_type == 4 )); then
      album=$(str_trim "$(print "$line" | cut -d\| -f4)" );
      duration=$(str_trim_left "$(print "$line" | cut -d\| -f5)" );
      current_row="    <tr>
      <td>
        <a href=\"$url\">$title</a><br>
        <span class=\"s3-left\">$author</span><span class=\"s3-right\">$album</span>
      </td>
      <td>$duration</td>
    </tr>";
    else
      stderr "    <error>$url</error>";
    fi

    stdout "$current_row";
  done;

  external_tags="  </table>
  <br>
</details>";
  stdout "$external_tags";
}
