function convert_seconds_to_timer_form() {
  local -r duration="$1";

  local dur;
  dur=$(transpose_duration "$duration");

  if str_contains "$dur" "→"; then
    dur=$(print "$dur" | grep -o -P "(?<=→ ).*(?=$)");
  fi
  dur=$(str_replace "$dur" "m" ":");
  dur=$(str_remove "$dur" "s");

  local seconds;
  local minutes;
  seconds=$(echo "$dur" | grep -o -P "(?<=:).*(?=$)");
  if (( "$#seconds" == 1 )); then
    seconds="0$seconds";
    minutes=$(echo "$dur" | grep -o -P "(?<=^).*(?=:)");
    dur="$minutes:$seconds";
  fi
  stdout "$dur";
}


