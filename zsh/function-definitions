# f: "$html" -> string | <...>
function to_steam_record_from_html() {
  local html="$1";
  local page_title;
  page_title=$(str_between_by_index "$html" '<title>' '</title>');
  if str_equals "$page_title" 'Sign In'; then
    stderr "[$0] requires login to verify age";
    return 1;
  elif str_equals "$page_title" 'Welcome to Steam'; then
    stderr "[$0] delisted";
    return 2;
  fi

  local content;
  content=$(str_between_by_index "$html" 'appDetailsUnderlinedLinks' '<div class="details_block');

  local title;
  title=$(str_between_by_index "$content" '<b>Title:</b> ' '<br>');
  if str_empty "$title"; then
    stderr "[$0] empty content";
    return 83;
  fi

  local developers;
  developers=$(___extract_from_steam_dev_row "$content" 'Developer');

  local publishers;
  publishers=$(___extract_from_steam_dev_row "$content" 'Publisher');

  local release_date;
  local size;
  release_date=$(str_between_by_index "$content" 'Release Date:</b> ' '<br>');
  release_date=$(str_remove "$release_date" ',');
  size=${#release_date};
  if [[ size -gt 12 ]]; then
    release_date=${release_date:0:11};
  fi
  release_date=$(date --date="$release_date" --iso-8601);

  local store_url;
  store_url=$(str_between_by_index "$html" '<link rel="canonical" href="' '">');

  local appid;
  appid=$(str_after "$store_url" 'app/');
  appid=$(str_before "$appid" '/');

  local now;
  local output;
  now=$(date -I);
  output="$title | $developers | $publishers | $release_date | $appid | __size__ | #created:$now #game #_ | $store_url";
  output=$(convert_html_entities_to_characters "$output");
  stdout "$output";
  return 0;
}
