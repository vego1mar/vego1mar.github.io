# f: "$content" 'Developer|Publisher' -> string | <...>
function ___extract_from_steam_dev_row() {
  local content="$1";
  local start="$2";

  local value;
  value=$(str_between_by_index "$content" "$start" '</div>');
  local full_str="";

  if str_contains "$value" ", "; then
    local occurrences;
    occurrences=$(str_count_occurrences "$value" ">, ");
    local dev="";
    while [ "$occurrences" -gt -1 ]; do
      dev=$(str_between_by_index "$value" '">' '<');
      full_str+="$dev, ";
      value=$(str_after "$value" '>, ');
      occurrences=$((occurrences - 1));
    done
    full_str=${full_str:0:-2};
  else
    value=$(str_between_by_index "$value" '">' '</a>');
    full_str="$value";
  fi
  
  full_str=$(str_trim "$full_str");
  if (str_starts_with "$full_str" ',') || (str_empty "$full_str"); then
    # no publisher, e.g.:
    # https://store.steampowered.com/app/401632/Batman_Arkham_Knight__WayneTech_Track_Pack/
    # https://store.steampowered.com/app/333800/Lords_of_the_Fallen___Ancient_Labyrinth/
    full_str="_";
  fi

  stdout "$full_str";
}

# to_steam_record https://store.steampowered.com/app/* -> string | <network>
function to_steam_record() {
  local url="$1";

  # https://stackoverflow.com/questions/66916403/bypass-age-check-on-steam-website-with-php-curl
  # https://stackoverflow.com/questions/15995919/how-to-use-curl-to-send-cookies#15996114
  # https://stackoverflow.com/questions/31394570/steam-curl-login-get-cookie-sessionid-multiple-requests
  # https://www.reddit.com/r/Steam/comments/qxcfh8/where_does_steam_browser_save_cookies_and_cache/
  # https://stackoverflow.com/questions/31394570/steam-curl-login-get-cookie-sessionid-multiple-requests
  # ~/.local/share/Steam/config/htmlcache
  local html;
  html=$(curl --no-progress-meter -L --cookie="birthtime=470682001;lastagecheckage=1-0-1985;" "$url");

  local record;
  local link;
  local appid;
  record=$(to_steam_record_from_html "$html");
  if [[ $? == 2 ]]; then
    appid=$(str_between_by_index "$url" 'app/' '/');
    link="https://steamdb.info/app/$appid/";
    stderr "[$0] try: $link";
    return 3;
  fi

  stdout "$record";
  return 0;
}

