function save_jd2_rss_history_2() {
  local -r mfdir_not_set=1;
  local -r mfprog_not_set=2;
  local -r mfdir_is_not_a_directory=3;
  local -r mfprog_not_executable_permission=4;
  local -r cd_failed=5;

  if str_empty "$mf_dir"; then stderr "[$0] mf directory not set"; return $mfdir_not_set; fi
  if str_empty "$mf"; then stderr "[$0] mf program not set"; return $mfprog_not_set; fi
  mf="$mf_dir/$mf";
  if ! does_directory_exists "$mf_dir"; then stderr "[$0] mf directory is not a directory"; return $mfdir_is_not_a_directory; fi
  if ! has_execution_permission "$mf"; then stderr "[$0] mf program is not an executable file"; return $mfprog_not_executable_permission; fi

  local -r input="$1";
  local -r previous_pwd=$(pwd);
  local -r n_lines=$(print "$1" | wc -l);
  cd "$mf_dir" || { stderr "[$0] cd failed"; exit $cd_failed; };

  local entry;
  local response;
  local video_id_2
  local video_id_3;
  local video_name;
  local followed_link;
  local before;
  for ((i=1; i <= n_lines; i++)); do
     entry=$(print "$input" | cut -d $'\n' -f"$i");
     video_id_3=$(print "$entry" | rev | cut -c1-11 | rev);

     if str_empty "$entry"; then
       # stdout "[$0] ❌ $i/$n_lines (empty line)";
       continue;
     elif str_starts_with "$entry" '#' || str_starts_with "$entry" ';'; then
       # stdout "[$0] ❌ $i/$n_lines (comment)";
       continue;
     elif str_contains "$entry" "youtu.be"; then
       followed_link=$(curl --head --no-progress-meter "$entry" | grep -i 'location' | cut -d' ' -f2 | cut -c1-43);
       stderr "[$0] ❌ $i/$n_lines $video_id_3 (youtube short link ($followed_link))";
       entry="$followed_link";
     elif ! str_contains "$entry" "youtube.com"; then
       before=$(str_between "$entry" '\.' '/');
       before=$(str_before "$before" '/');
       stderr "[$0] ❌ $i/$n_lines (non-youtube link ($before))";
       continue;
     elif str_contains "$entry" "timedtext"; then
       video_id_2=$(str_between "$entry" "timedtext" "\&" | cut -c4-14);
       stderr "[$0] ❌ $i/$n_lines $video_id_2 (subtitle link)";
       continue;
     elif str_contains "$entry" "&"; then
       local -r video_id=${entry:32:11};
       stderr "[$0] ❌ $i/$n_lines $video_id (link with attributes)";
       entry=${entry:0:43};
     fi

     if ! response=$("$mf" "$entry"); then
       stderr "[$0] ❌ $i/$n_lines $video_id_3 ($response)";
     else
       video_name=$(str_between "$response" "⌜" "⌝");
       stdout "[$0] ✅ $i/$n_lines $video_id_3 ($video_name)" >/dev/tty;
       stdout "$response" >&1;
     fi
   done

  local tmp_file_1="page.char.tmp";
  local tmp_file_2="page.html.tmp";
  if file_exists "$tmp_file_1"; then rm ./"$tmp_file_1"; fi
  if file_exists "$tmp_file_2"; then rm ./"$tmp_file_2"; fi
  cd "$previous_pwd" || { stderr "[$0] cd failed"; exit $cd_failed; };
  return 0;
}

