# fetch_rss_url https://www.youtube.com/@ah/videos
function fetch_rss_url() {
  local url="$1";
  local loc;
  loc=$(curl --no-progress-meter --head "$url" | grep -i "location" | cut -d' ' -f2 | xargs);

  local response;
  local rss_url;
  if str_empty "$loc"; then
    response=$(curl --no-progress-meter "$url");
  else
