# f: number -> string | <...>
function convert_seconds_to_duration() {
  local secs="$1";
  local output;
  output=$(printf "%dd%dh%dm%ds\n" $((secs/86400)) $((secs%86400/3600)) $((secs%3600/60)) $((secs%60)));
  if str_starts_with "$output" "0d";      then output=$(str_remove "$output" "0d");     fi
  if str_starts_with "$output" "0h";      then output=$(str_remove "$output" "0h");     fi
  if str_starts_with "$output" "0m";      then output=$(str_remove "$output" "0m");     fi
  if str_contains    "$output" "0h0m";    then output=$(str_remove "$output" "0h0m");   fi
  if str_ends_with   "$output" "d0s";     then output=$(str_remove "$output" "0s");     fi
  if str_ends_with   "$output" "h0m0s";   then output=$(str_remove "$output" "0m0s");   fi
  if str_contains    "$output" "h0m";     then output=$(str_remove "$output" "0m");     fi
  if str_ends_with   "$output" "d0h0m0s"; then output=$(str_remove "$output" "0h0m0s"); fi
  if str_contains    "$output" "d0h";     then output=$(str_remove "$output" "0h");     fi
  if str_ends_with   "$output" "m0s";     then output=$(str_remove "$output" "0s");     fi
  stdout "$output";
}
