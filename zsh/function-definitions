# str_trim_left "str" -> string
function str_trim_left() {
  local -r var="$1";

  local trim;
  local hit_non_whitespace="false";
  local -r len=$#var;
  local j;
  for (( i=1; i<=len; i++ )); do
    case "${var[$i]}" in
      $'\v')
        #stderr "[$0] $i (v) vertical tabulator";
        ;;
      $'\t')
        #stderr "[$0] $i (t) tabulator";
        ;;
      $'\r')
        #stderr "[$0] $i (↵) carriage return";
        ;;
      $'\f')
        #stderr "[$0] $i (↵) line feed";
        ;;
      $'\n')
        #stderr "[$0] $i (↵) newline";
        ;;
      [[:space:]])
        #stderr "[$0] $i (${var[$i]}) space";
        ;;
      (*)
        #stderr "[$0] $i (${var[$i]}) *";
        hit_non_whitespace="true";
        ;;
    esac
    if str_equals "$hit_non_whitespace" "true"; then
      j=$i;
      break;
    fi
  done

  trim=${var:$j-1:$len};
  stdout "$trim";
}
