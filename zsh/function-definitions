# f: https://windows10spotlight.com/images/[0-9]+ -> string | <network>
function fetch_record_from_windows10spotlightcom() {
  # fetch_record_from_windows10spotlightcom https://windows10spotlight.com/images/41117
  local url="$1";

  local html;
  local content;
  html=$(curl --no-progress-meter "$url");
  if str_empty "$html"; then
    stderr "[$0] curl failed";
    return 222;
  fi
  if str_contains "$html" "<h1>Oops! That page can&rsquo;t be found.</h1>"; then
    stderr "[$0] that page can’t be found";
    return 111;
  fi

  local record;
  record=$(to_record_of_windows10spotlightcom_from_html "$html");
  stdout "$record";
}

# f: "https://windows10spotlight.com/images/[0-9]+\n..." -> string | <network> <filesystem>
function download_images_from_windows10spotlightcom() {
  # download_images_from_windows10spotlightcom "https://windows10spotlight.com/images/41117\nhttps://windows10spotlight.com/images/41121"

  local input="$1"
  local n_lines;
  local i;
  local record;
  local records;
  local record_date;
  local file_name;
  local jpg_link;
  local suffix='a';

  n_lines=$(print "$input" | wc -l);

  for (( i=1; i<=n_lines; i++ )); do
    url=$( awk 'NR=='"$i" <(print "$input") );
    if ! (str_starts_with "$url" "https://windows10spotlight.com"); then
      stderr "[$0] ($i) not in domain windows10spotlight.com";
      return 11;
    fi
    if ! (str_starts_with "$url" "https://windows10spotlight.com/images/"); then
      stderr "[$0] ($i) not at /images pages";
      return 22;
    fi

    record=$(fetch_record_from_windows10spotlightcom "$url");
    record_date=$(print "$record" | cut -d\| -f1);
    file_name=$(print "$record_date" | cut -c3-4,6-7,9-10);
    file_name+="$suffix.jpg";
    suffix=$(get_next_glyph "$suffix");
    jpg_link=$(print "$record" | cut -d\| -f5);
    jpg_link=$(str_trim_left "$jpg_link");

    curl --output="$file_name" --progress-bar --styled-output "$jpg_link";
    records+="$record\n"
  done

  stdout "$records";
}

# f: "$html" -> string | <...>
function extract_youtube_record_from_html() {
  local html="$1";
  local metadata;
  metadata=$(str_between_by_index "$html" 'playerMicroformatRenderer":' "</script>");

  local playability_status;
  local video_status;
  local is_ok="true";
  playability_status=$(str_between_by_index "$html" 'playabilityStatus' '},"');
  video_status=$(str_between_by_index "$playability_status" 'status":"' '",');
  video_status=$(str_to_lowercase "$video_status");
  if str_empty "$video_status"; then
    stderr "[$0] no playabilityStatus found";
    return 1;
  fi
  if (str_equals "$video_status" "error") || (str_equals "$video_status" "login_required"); then
    is_ok="false";
  fi

  local simple_text="_";
  local info_text="_";
  local extra_tags="";
  local is_unlisted;
  if (str_equals "$is_ok" "false") && (str_equals "$video_status" "error"); then
    simple_text=$(str_between_by_index "$html" 'reason":{"simpleText":"' '"}');
    info_text=$(str_between_by_index "$html" 'backgroundPromoRenderer":' 'trackingParams');
    info_text=$(str_between_by_index "$html" 'text":"' '"}]');
    if str_contains "$simple_text" "Video unavailable"; then
      extra_tags="#unavailable_video ";
    fi
  elif (str_equals "$is_ok" "false") && (str_equals "$video_status" "login_required"); then
    simple_text=$(str_between_by_index "$html" 'reason":{"simpleText":"' '"}');
    info_text=$(str_between_by_index "$html" '"reason":{"simpleText":"' '"}');
    if str_contains "$info_text" "Private video"; then
      extra_tags="#private_video ";
    fi
    if (! str_empty "$metadata") && (str_equals "$simple_text" "$info_text"); then
      simple_text=$(str_between_by_index "$metadata" 'simpleText":"' '"}');
      simple_text=$(str_replace "$simple_text" '|' '｜');
      is_ok="true";
      extra_tags+="#age_check ";
    fi
  else
    simple_text=$(str_between_by_index "$metadata" 'simpleText":"' '"}');
    simple_text=$(str_replace "$simple_text" '|' '｜');
    is_unlisted=$(str_between_by_index "$metadata" 'isUnlisted":' ',');
    if str_equals "$is_unlisted" "true"; then extra_tags+="#unlisted "; fi
  fi
  simple_text=$(convert_html_entities_to_characters "$simple_text");

  local available_countries;
  local arr_countries;
  local n_countries;
  local locked_countries;
  if str_equals "$is_ok" "true"; then
    available_countries=$(str_between_by_index "$metadata" 'availableCountries":[' ']');
    available_countries=$(print "$available_countries" | tr -d '"' | tr ',' ' ');
    arr_countries=("${=available_countries}");
    n_countries=${#arr_countries};
    if [ "$n_countries" != 249 ]; then
      # https://watannetwork.com/tools/blocked/#url=ObRfaHudQtU
      locked_countries=$(___find_region_locked_countries "$available_countries");
      extra_tags+="#region_locked:$locked_countries "
    fi
  fi

  local duration="_";
  local publish_date="_";
  local channel_id="_";
  local profile_id="_";
  local channel_name="_";
  local category="_";
  local canonical_url="_";
  local original_url="_"
  local view_count="_";
  local like_count="_";
  if str_equals "$is_ok" "true"; then
    if str_equals "$video_status" "live_stream_offline"; then
      duration="0s";
    else
      duration=$(str_between_by_index "$metadata" 'lengthSeconds":"' '",');
      duration=$(convert_seconds_to_duration "$duration");
    fi

    publish_date=$(str_before "$(str_between_by_index "$metadata" 'publishDate":"' '",')" 'T' );
    channel_id=$(str_between_by_index "$metadata" 'externalChannelId":"' '",');
    profile_id=$(str_between_by_index "$metadata" 'ownerProfileUrl":"' '",');
    profile_id=$(str_after "$profile_id" "http://www.youtube.com/");
    if str_starts_with "$profile_id" "channel"; then
      profile_id="";
      extra_tags+="#topic ";
    fi
    profile_id=$(decode_percent_encoding "$profile_id");
    channel_name=$(str_between_by_index "$metadata" 'ownerChannelName":"' '",');
    channel_name=$(str_replace "$channel_name" '|' '｜');
    category=$(str_between_by_index "$metadata" 'category":"' '",');
    category=$(str_to_lowercase "$category");
    category=$(str_replace "$category" '&' 'and');
    category=$(str_replace "$category" ' ' '_');
    canonical_url=$(str_between_by_index "$metadata" 'canonicalUrl":"' '"}');
    original_url=$(str_between_by_index "$html" 'originalUrl":"' '",');
    original_url=$(decode_percent_encoding "$original_url");
    view_count=$(str_between_by_index "$metadata" 'viewCount":"' '",');
    if ! is_number "$view_count"; then view_count="0"; fi
    like_count=$(str_between_by_index "$metadata" 'likeCount":"' '",');
    if ! is_number "$like_count"; then like_count="0"; fi
  fi

  local now;
  local hash;
  local output;
  local canonical_link;
  local canonical_video_id;
  local original_video_id;
  local qualified_name;
  now=$(date -I);
  canonical_video_id=$(str_between_by_index "$html" '"videoId":"' '"');
  if str_equals "$is_ok" "false"; then
    canonical_link="https://www.youtube.com/watch?v=$canonical_video_id";
    output="$simple_text | $info_text | _ | _ | _ | __hash__ | #created:$now #$video_status $extra_tags| $canonical_link";
  else
    if str_contains "$original_url" '?v='; then
      original_video_id=$(str_after "$original_url" '?v=');
    elif str_contains "$original_url" 'shorts/'; then
      original_video_id=$(str_after "$original_url" 'shorts/');
    fi
    if ! str_equals "$original_video_id" "$canonical_video_id"; then
      canonical_link="https://www.youtube.com/watch?v=$original_video_id → $canonical_video_id";
      canonical_url="$canonical_link";
    fi
    qualified_name="$profile_id [$channel_name]";
    if str_empty "$profile_id"; then qualified_name="[$channel_name]"; fi
    output="$simple_text | $qualified_name | $publish_date | $duration | $channel_id | __hash__ | ";
    output+="#created:$now #$category #$video_status $extra_tags#views:$view_count #likes:$like_count | $canonical_url";
  fi

  local hash_data;
  hash_data="$simple_text‚$profile_id‚$channel_name‚$publish_date‚$duration‚$channel_id‚$now‚$category‚$video_status‚$extra_tags‚$view_count‚$like_count‚$canonical_url";
  hash=$(print "$hash_data" | xxh64sum | cut -c1-16);
  output=$(str_replace "$output" "__hash__" "$hash");

  stdout "$output";
  return 0;
}
