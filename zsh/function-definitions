# f: $available_countries -> string | <...>
function ___find_region_locked_countries() {
  local available_countries="$*";
  local expected_countries='AD AE AF AG AI AL AM AO AQ AR AS AT AU AW AX AZ BA BB BD BE BF BG BH BI BJ BL BM BN BO BQ BR BS BT BV BW BY BZ CA CC CD CF CG CH CI CK CL CM CN CO CR CU CV CW CX CY CZ DE DJ DK DM DO DZ EC EE EG EH ER ES ET FI FJ FK FM FO FR GA GB GD GE GF GG GH GI GL GM GN GP GQ GR GS GT GU GW GY HK HM HN HR HT HU ID IE IL IM IN IO IQ IR IS IT JE JM JO JP KE KG KH KI KM KN KP KR KW KY KZ LA LB LC LI LK LR LS LT LU LV LY MA MC MD ME MF MG MH MK ML MM MN MO MP MQ MR MS MT MU MV MW MX MY MZ NA NC NE NF NG NI NL NO NP NR NU NZ OM PA PE PF PG PH PK PL PM PN PR PS PT PW PY QA RE RO RS RU RW SA SB SC SD SE SG SH SI SJ SK SL SM SN SO SR SS ST SV SX SY SZ TC TD TF TG TH TJ TK TL TM TN TO TR TT TV TW TZ UA UG UM US UY UZ VA VC VE VG VI VN VU WF WS YE YT ZA ZM ZW';
  local expected=("${=expected_countries}");
  local countries=("${=available_countries}");

  # https://unix.stackexchange.com/questions/606070/how-to-iterate-over-array-indices-in-zsh
  # https://unix.stackexchange.com/questions/411304/how-do-i-check-whether-a-zsh-array-contains-a-given-value
  local country_code;
  local codes="";
  for country_code in "${expected[@]}"; do
    # shellcheck disable=SC1073
    # shellcheck disable=SC1072
    if ! (($countries[(Ie)$country_code])); then
      codes+="$country_code,";
    fi
  done

  codes=${codes:0:-1};
  codes=${(L)codes};
  stdout "$codes";
}

# f: "https://www.youtube.com/[watch?v=|shorts/]*|https://youtu.be/*" -> string | <network>
function fetch_youtube_record() {
  local url="$1";
  local ret_not_youtube_link=141;
  local ret_curl_failed=142;

  local is_valid_link="false";
  if str_starts_with "$url" "https://www.youtube.com/watch?v="; then is_valid_link="true"; fi
  if str_starts_with "$url" "https://www.youtube.com/shorts/"; then is_valid_link="true"; fi
  if str_starts_with "$url" "https://youtu.be"; then is_valid_link="true"; fi
  url=$(decode_percent_encoding "$url");

  if str_equals "$is_valid_link" "false"; then
    stderr "[$0] not youtube link ($url)";
    return "$ret_not_youtube_link";
  fi

  # https://stackoverflow.com/questions/15071298/curl-set-language-header
  local html;
  html=$(curl -L -s -H 'Accept-Language: en' -XGET --no-progress-meter "$url");
  if str_empty "$html"; then
    stderr "[$0] curl failed ($url)";
    return "$ret_curl_failed";
  fi

  local record;
  record=$(extract_youtube_record_from_html "$html");
  stdout "$record";
}

# f: "https://www.youtube.com/watch?v=*\n..." -> string | <network> <terminal>
function fetch_youtube_records() {
  # str=$(cat ~/library/roboczy/app-data/yt-dlp/links.txt); fetch_youtube_records "$str" > ~/library/roboczy/app-data/yt-dlp/yt-hist-daily.txt
  local input="$1";
  local n_lines;
  local m_lines=0;
  local line;
  local i;
  local is_comment="false";
  local is_valid_link="false";
  local raw_input="";

  n_lines=$(print "$input" | wc -l);
  for ((i=1; i <= n_lines; i++)); do
    line=$( awk 'NR=='"$i" <(print "$input") );
    if str_empty "$line"; then continue; fi

    is_comment="false";
    is_valid_link="false";
    line=$( print "$line" | cut -d\| -f1 );
    line=$( str_trim_right "$line" );
    if str_starts_with "$line" "#";  then is_comment="true"; fi
    if str_starts_with "$line" ";";  then is_comment="true"; fi
    if str_starts_with "$line" "https://www.youtube.com/"; then is_valid_link="true"; fi
    if str_starts_with "$line" "https://youtu.be"; then is_valid_link="true"; fi
    if str_equals "$is_comment" "true"; then continue; fi
    if str_equals "$is_valid_link" "false"; then continue; fi

    raw_input+="$line\n";
    m_lines=$(( m_lines + 1 ));
  done
  raw_input=${raw_input:0:-1};

  local link;
  local record;
  local profile_id;
  local short_video_name;
  for (( i=1; i<=m_lines; i++ )); do
    link=$( awk 'NR=='"$i" <(print "$raw_input") );
    record=$(fetch_youtube_record "$link");
    if str_empty "$record"; then
      stderr "❌ $i/$m_lines ($link)" >/dev/tty;
      stdout "<error>$link</error>" >&1;
      continue;
    fi

    profile_id=$(print "$record" | cut -d\| -f2);
    profile_id=$(str_before "$profile_id" '[');
    profile_id=$(str_trim "$profile_id");
    short_video_name=$(print "$record" | cut -d\| -f1 | cut -c1-121);
    short_video_name=${short_video_name:0:-1};
    stdout "✅ $i/$m_lines $profile_id ($short_video_name)" >/dev/tty;
    stdout "$record" >&1;
  done

  return 0;
}

