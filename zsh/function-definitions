# str_trim_right "word "
# str_trim_right "word  "
# str_trim_right "aaa bbb  "$'\t'
# str_trim_right "some word  "$'\t'"   "
function str_trim_right() {
  local -r var="$1";

  local trim;
  local hit_non_whitespace="false";
  local -r len=$#var;
  local j;
  for (( i=len; i>0; i-- )); do
    case "${var[$i]}" in
      $'\v')
        #stderr "[$0] $i (v) vertical tab";
        ;;
      $'\t')
        #stderr "[$0] $i (t) tab";
        ;;
      $'\r')
        #stderr "[$0] $i (↵) carriage return";
        ;;
      $'\f')
        #stderr "[$0] $i (↵) line feed";
        ;;
      $'\n')
        #stderr "[$0] $i (↵) newline";
        ;;
      [[:space:]])
        #stderr "[$0] $i (${var[$i]}) space";
        ;;
      (*)
        #stderr "[$0] $i (${var[$i]}) *";
        hit_non_whitespace="true";
        ;;
    esac
    if str_equals "$hit_non_whitespace" "true"; then
      j=$i;
      break;
    fi
  done

  trim=${var:0:$j};
  stdout "$trim";
}

# str_trim " word "
# str_trim "  word  "
# str_trim $'\n'"  aaa bbb  "$'\t'
# str_trim "  "$'\v'"some word  "$'\t'"   "
function str_trim() {
  local var="$1";
  local trim;
  trim=$(str_trim_left "$var");
  trim=$(str_trim_right "$trim");
  stdout "$trim";
}

