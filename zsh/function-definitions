# str_between "omar namji, laura intravia, bharat raman" 'l' "rat"
# str_between "@theophanyremix | ⌜midra lord of frenzied flame (vocal remake) | elden ring (no ai)⌝ | 2025-12-05" '⌜' '⌝'
function str_between() {
  local input="$1";
  local left="$2";
  local right="$3";

  local result;
  result=$(print "$input" | grep -o -P "(?<=$left).*(?=$right)");
  stdout "$result";
}

# str_between_by_index "str" "left" "right" -> string
function str_between_by_index() {
  # https://unix.stackexchange.com/questions/459497/zsh-equivalent-of-bashs-expr-index-abcdefghijklmnopqrstuvwxyz-xyzd
  local string="$1";
  local word="$2";
  local index;
  local content;

  index="${(SB)string#$word}";
  index=$(( index + $(str_len "$word") - 1 ));
  content=${string:$index};

  word="$3";
  index="${(SB)content#$word}";
  index=$(decrement "$index");
  content=${content:0:$index};

  stdout "$content";
}
